---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { CABINET } from "@consts"
import { formatDate } from "@lib/utils"

const collection = await getCollection("cabinet", ({ data }) => !data.draft)

collection.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)

const fragments = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render()
    return { ...item, Content }
  })
)

function hostnameOf(url: string) {
  try {
    return new URL(url).hostname.replace(/^www\./, "")
  } catch {
    return url
  }
}
---

<PageLayout title={CABINET.TITLE} description={CABINET.DESCRIPTION}>
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-ink-900 mt-2">
        {CABINET.TITLE}
      </h1>
      <p class="mt-1 text-ink-700">
        {CABINET.DESCRIPTION}
      </p>
    </div>
  </TopLayout>
  <BottomLayout>
    {fragments.length === 0 ? (
      <div class="animate text-ink-700 italic">
        The cabinet is empty for now &mdash; come back soon.
      </div>
    ) : (
      <ul class="animate space-y-6">
        {fragments.map((entry) => (
          <li class="group p-5 border rounded-lg border-olive-700/20 bg-bean-50/40 hover:bg-olive-700/[0.04] transition-colors duration-300 ease-in-out">
            <div class="flex flex-wrap items-center justify-between gap-2 text-xs uppercase tracking-wide text-ink-700">
              <time datetime={entry.data.date.toISOString()}>
                {formatDate(entry.data.date)}
              </time>
              {entry.data.tags && entry.data.tags.length > 0 && (
                <ul class="flex flex-wrap gap-1">
                  {entry.data.tags.map((tag: string) => (
                    <li class="py-0.5 px-2 rounded bg-olive-700/10 text-ink-700 normal-case tracking-normal">
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
            </div>

            {entry.data.title && (
              <h2 class="mt-3 text-lg font-semibold text-ink-900">
                {entry.data.title}
              </h2>
            )}

            {entry.data.sourceUrl && (
              <a
                href={entry.data.sourceUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 inline-flex max-w-full items-center gap-1.5 px-2.5 py-1 rounded border border-olive-700/20 bg-bean-100 text-sm text-olive-700 hover:bg-olive-700/10 hover:text-olive-900 transition-colors duration-300 ease-in-out"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="size-3.5 shrink-0"
                >
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                </svg>
                <span class="truncate">
                  {entry.data.sourceTitle || hostnameOf(entry.data.sourceUrl)}
                </span>
              </a>
            )}

            <article class="prose mt-3">
              <entry.Content />
            </article>
          </li>
        ))}
      </ul>
    )}
  </BottomLayout>
</PageLayout>
