---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import StackCard from "@components/StackCard.astro"
import { SITE, SOCIALS } from "@consts"

const posts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)

const stack = [
  { 
    text: "Astro", 
    icon: "astro", 
    href: "https://astro.build" 
  },
  { 
    text: "Javascript", 
    icon: "javascript", 
    href: "https://www.javascript.com" 
  },
  { 
    text: "Typescript", 
    icon: "typescript", 
    href: "https://www.typescriptlang.org" 
  },
  { 
    text: "Tailwind", 
    icon: "tailwind", 
    href: "https://tailwindcss.com" 
  },
]
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>

  <!-- HERO -->
  <section class="relative h-screen w-full overflow-hidden">
    <!-- 静态装饰：底部居中柔和的橄榄绿径向渐变 -->
    <div class="pointer-events-none absolute -bottom-1/4 left-1/2 -translate-x-1/2 w-[140vw] h-[90vh] rounded-full bg-gradient-radial from-olive-300/40 via-olive-300/10 to-transparent blur-3xl"></div>
    <!-- 静态装饰：右上角浅一点的辅助渐变圆 -->
    <div class="pointer-events-none absolute -top-1/4 -right-1/4 w-[60vw] h-[60vw] rounded-full bg-gradient-radial from-olive-500/15 to-transparent blur-3xl"></div>

    <div class="animate absolute h-full w-full flex items-center justify-center">
      <div class='relative w-full h-full flex items-center justify-center'>
        <div class='p-5 text-center'>
          <p class='animated text-lg md:text-xl lg:text-2xl font-semibold text-ink-700/80'>
            Hi~ Welcome to ...
          </p>
          <p class='animated text-2xl md:text-3xl lg:text-4xl font-bold uppercase text-ink-900 mt-1'>
            Anosia's Grove
          </p>
          <p class='animated text-sm md:text-base lg:text-lg text-ink-700/70 italic mt-2'>
            l'homme de nature et de la vérité
          </p>
          <div id="ctaButtons" class='animated flex flex-wrap gap-4 justify-center mt-6'>
            <a href='/blog' class='py-2 px-4 rounded truncate text-xs md:text-sm lg:text-base bg-olive-700 text-bean-50 hover:bg-olive-900 blend'>
              Read my blog
            </a>
            <a href='/education' class='py-2 px-4 truncate rounded text-xs md:text-sm lg:text-base border border-olive-700 text-olive-700 hover:bg-olive-700/10 blend'>
              View my education
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="relative bg-bean-100">
    <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">

      <!-- About Section -->
      <!-- TODO: 在这里写自我介绍。可以删掉占位内容，按下方骨架自由发挥。 -->
      <section class="animate">
        <article>
          <h2 class="text-ink-900">关于我</h2>
          <p>
            <i>（占位文本，等待替换。可以写：你是谁、在哪里念书、在折腾什么、为什么做这个网站。）</i>
          </p>
          <p>
            Hello, I'm <strong>Vivian (Anosia)</strong>. 一个 PolyU CS + Finance 在读学生，喜欢折腾，喜欢闭谈。
          </p>
          <p>
            这里会记录我学到的、做过的、想过的东西。慢慢更新中。
          </p>
        </article>
      </section>

      <!-- Blog Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-ink-900">
              Recent posts
            </p>
            <a href="/blog" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-olive-700/40 hover:decoration-olive-700 text-olive-700 underline-offset-2 blend">
              <span class="text-ink-700 group-hover:text-olive-900 blend">
                All posts
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {posts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Tech Stack Section -->
      <section class="animate">
        <div class="space-y-4">
          <p class="font-semibold text-ink-900">
            Website build with
          </p>
          <div class="flex flex-wrap items-center gap-2 mt-5">
            {stack.map(item => (
              <StackCard 
                text={item.text}
                icon={item.icon}
                href={item.href}
              />
            ))}
          </div>
          <div>
            Performing reactivity and statefulness, special guest
            <a href="https://www.solidjs.com/" target="_blank" class="w-fit group underline decoration-[.5px] decoration-olive-700/40 hover:decoration-olive-700 text-olive-700 underline-offset-2 blend">
              <span class="text-ink-700 group-hover:text-olive-900 blend">
                SolidJS
              </span>
            </a>
          </div>
        </div>
      </section>

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-ink-900">
              Recent projects
            </p>
            <a href="/projects" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-olive-700/40 hover:decoration-olive-700 text-olive-700 underline-offset-2 blend">
              <span class="text-ink-700 group-hover:text-olive-900 blend">
                All projects
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <p class="font-semibold text-ink-900">
            Let's Connect
          </p>
          <p>
            Reach out to me via email or on social media.
          </p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {SOCIALS.map(social => (
              <div class="col-span-1 flex items-center gap-1">
                <span class="whitespace-nowrap truncate">
                  {social.NAME}
                </span>
              </div>
              <div class="col-span-3 truncate">
                <a href={social.HREF} target="_blank" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-olive-700/40 hover:decoration-olive-700 text-olive-700 underline-offset-2 blend">
                  <span class="text-ink-700 group-hover:text-olive-900 blend">
                    {social.TEXT}
                  </span>
                </a>
              </div>
            ))}
        </div>
      </section>
    </div>
  </div>
</PageLayout>
