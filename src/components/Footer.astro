---
import { SITE, SOCIALS } from "@consts"
import Container from "@components/Container.astro"
---

<footer class="relative bg-bean-100">
  <div class="animate">
    <section class="py-5">
      <Container size="md">
        <div class="flex items-center justify-center sm:justify-end">
          <button id="back-to-top" aria-label="Back to top of page" class="group flex w-fit p-1.5 gap-1.5 text-sm items-center border rounded hover:bg-olive-700/10 border-olive-700/20 transition-colors duration-300 ease-in-out">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="stroke-current group-hover:stroke-olive-700 rotate-90">
              <line x1="19" y1="12" x2="5" y2="12" class="scale-x-0 group-hover:scale-x-100 translate-x-3 group-hover:translate-x-0 transition-all duration-300 ease-in-out" />
              <polyline points="12 19 5 12 12 5" class="translate-x-1 group-hover:translate-x-0 transition-all duration-300 ease-in-out" />
            </svg>
            <div class="w-full group-hover:text-olive-700 transition-colors duration-300 ease-in-out">
              Back to top
            </div>
          </button>
        </div>
      </Container>
    </section>
  
    <section class=" py-5 overflow-hidden whitespace-nowrap border-t border-bean-200">
      <Container size="md">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="flex flex-col items-center sm:items-start">
            <a href="/" class="flex gap-1 w-fit font-semibold text-current hover:text-olive-700 transition-colors duration-300 ease-in-out">
              <svg class="size-6 fill-current">
                <use href="/brand.svg#brand"/>
              </svg>
              {SITE.TITLE}
            </a>
          </div>
          <div
            class="flex flex-col sm:flex-row gap-1 sm:gap-4 justify-center sm:justify-end items-center text-sm"
            data-launch-date={SITE.LAUNCH_DATE}
            data-goatcounter-code={SITE.GOATCOUNTER_CODE}
          >
            <div class="flex gap-2 items-center">
              <span class="relative flex h-3 w-3">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-300"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
              </span>
              <span>Grove uptime:&nbsp;<span id="grove-uptime" class="tabular-nums">—</span></span>
            </div>
            <div>
              Visitors:&nbsp;<span id="grove-visitors" class="tabular-nums">—</span>
            </div>
          </div>
        </div>
      </Container>
    </section>
  
    <section class=" py-5 overflow-hidden whitespace-nowrap border-t border-bean-200">
      <Container size="md">
        <div class="h-full grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="order-2 sm:order-1 flex flex-col items-center justify-center sm:items-start">
            <div class="legal">
              <a href="/legal/terms" class="text-current hover:text-olive-700 transition-colors duration-300 ease-in-out">
                Terms
              </a> |
              <a href="/legal/privacy" class="text-current hover:text-olive-700 transition-colors duration-300 ease-in-out">
                Privacy
              </a>
            </div>
            <div class="text-sm mt-2">
              &copy; 2024 | All rights reserved
            </div>
          </div>
  
          <div class="order-1 sm:order-2 flex justify-center sm:justify-end">
            <div class="flex flex-wrap gap-1 items-center justify-center">
              {
                SOCIALS.map((SOCIAL) => (
                  <a 
                    href={SOCIAL.HREF} 
                    target="_blank" 
                    aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`} 
                    class="group size-10 rounded-full p-2 items-center justify-center hover:bg-olive-700/10 blend"
                  >
                    <svg class="size-full fill-current group-hover:fill-olive-700 blend">
                      <use href={`/social.svg#${SOCIAL.ICON}`} />
                    </svg>
                  </a>
                ))
              }
              </div>
          </div>
        </div>
      </Container>
    </section>
  </div>

</footer>

<script is:inline>
  function goBackToTop(event) {
    event.preventDefault()
    window.scrollTo({
        top: 0,
        behavior: "smooth"
    })
  }

  function initializeBackToTop() {
    const backToTop = document.getElementById("back-to-top")
    backToTop?.addEventListener("click", goBackToTop)
  }

  document.addEventListener("astro:after-swap", initializeBackToTop)
  initializeBackToTop()
</script>

<script is:inline>
  (function () {
    let uptimeTimer = null

    function renderUptime() {
      const el = document.getElementById("grove-uptime")
      if (!el) return
      const container = el.closest("[data-launch-date]")
      const launchStr = container?.getAttribute("data-launch-date")
      if (!launchStr) return
      const launch = new Date(launchStr).getTime()
      if (Number.isNaN(launch)) return

      const diff = Date.now() - launch
      if (diff < 0) {
        el.textContent = "launching soon"
        return
      }
      const sec = Math.floor(diff / 1000) % 60
      const min = Math.floor(diff / 60000) % 60
      const hr = Math.floor(diff / 3600000) % 24
      const day = Math.floor(diff / 86400000)
      el.textContent = `${day}d ${hr}h ${min}m ${sec}s`
    }

    function startUptime() {
      renderUptime()
      if (uptimeTimer) clearInterval(uptimeTimer)
      uptimeTimer = setInterval(renderUptime, 1000)
    }

    startUptime()
    document.addEventListener("astro:after-swap", startUptime)
  })()
</script>

<script is:inline define:vars={{ GOATCOUNTER_CODE: SITE.GOATCOUNTER_CODE }}>
  (function () {
    if (!GOATCOUNTER_CODE) return

    function loadGoatCounter() {
      if (document.getElementById("goatcounter-script")) return
      const s = document.createElement("script")
      s.id = "goatcounter-script"
      s.async = true
      s.src = "https://gc.zgo.at/count.js"
      s.setAttribute(
        "data-goatcounter",
        `https://${GOATCOUNTER_CODE}.goatcounter.com/count`
      )
      document.body.appendChild(s)
    }

    function fetchVisitors() {
      const el = document.getElementById("grove-visitors")
      if (!el) return
      fetch(
        `https://${GOATCOUNTER_CODE}.goatcounter.com/counter/TOTAL.json`,
        { mode: "cors" }
      )
        .then((r) => (r.ok ? r.json() : Promise.reject(r.status)))
        .then((data) => {
          const value = data.count_unique ?? data.count
          if (value != null) el.textContent = String(value)
        })
        .catch(() => {
          el.textContent = "—"
        })
    }

    loadGoatCounter()
    fetchVisitors()
    document.addEventListener("astro:after-swap", fetchVisitors)
  })()
</script>